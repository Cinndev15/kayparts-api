{
  "openapi": "3.0.0",
  "info": {
    "title": "Kayparts Node REST API",
    "version": "2.1",
    "description": "Complete API documentation for Kayparts REST API in Node.js, Express, and MySQL"
  },
  "servers": [
    {
      "url": "/api",
      "description": "Base API Path"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Sanctum (<id>|<plainTextToken>)"
      }
    }
  },
  "paths": {
    "/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Authenticate user and generate token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "juan@example.com" },
                  "password": { "type": "string", "format": "password", "example": "12345678" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "422": { "description": "Validation Error" }
        }
      }
    },
    "/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user and generate token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "Juan Perez" },
                  "email": { "type": "string", "format": "email", "example": "juan@example.com" },
                  "password": { "type": "string", "format": "password", "example": "12345678" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Registration successful" },
          "422": { "description": "Validation Error" }
        }
      }
    },
    "/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Logout user and delete token",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logout successful" },
          "401": { "description": "Unauthenticated" }
        }
      }
    },
    "/user": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get authenticated user profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "User profile retrieved" },
          "401": { "description": "Unauthenticated" }
        }
      }
    },
    "/shop/products": {
      "get": {
        "tags": ["Shop"],
        "summary": "List products with filters and pagination",
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "brand", "in": "query", "schema": { "type": "string" } },
          { "name": "year", "in": "query", "schema": { "type": "integer" } },
          { "name": "displacement", "in": "query", "schema": { "type": "string" } },
          { "name": "price_min", "in": "query", "schema": { "type": "number" } },
          { "name": "price_max", "in": "query", "schema": { "type": "number" } },
          { "name": "sort", "in": "query", "schema": { "type": "string", "enum": ["relevance", "price_low", "price_high", "newest"] } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 12 } }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/shop/filters": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get unique filters metadata",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/shop/products/{slug}": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get product details by slug",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Success" },
          "404": { "description": "Product not found" }
        }
      }
    },
    "/shop/makes": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get vehicle brands (makes) with active products",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/shop/models": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get vehicle models with active products",
        "parameters": [
          { "name": "make_id", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/shop/years": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get vehicle years with active products",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/shop/displacements": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get vehicle displacements with active products",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/shop/categories": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get categories with active products count",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/shop/vehicle-models/{makeId}": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get vehicle models by make ID",
        "parameters": [
          { "name": "makeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/checkout/process": {
      "post": {
        "tags": ["Checkout"],
        "summary": "Process checkout order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["items", "customer_name", "customer_email"],
                "properties": {
                  "customer_name": { "type": "string" },
                  "customer_email": { "type": "string", "format": "email" },
                  "customer_phone": { "type": "string" },
                  "shipping_address": { "type": "object" },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["product_id", "quantity"],
                      "properties": {
                        "product_id": { "type": "integer" },
                        "quantity": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Order created successfully" },
          "422": { "description": "Validation Error / Stock Out" }
        }
      }
    },
    "/workshop-applications": {
      "post": {
        "tags": ["Workshop Applications"],
        "summary": "Submit a workshop application",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["workshop_name", "owner_name", "email", "phone", "department", "city", "address"],
                "properties": {
                  "workshop_name": { "type": "string" },
                  "nit": { "type": "string" },
                  "owner_name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "phone": { "type": "string" },
                  "department": { "type": "string" },
                  "city": { "type": "string" },
                  "address": { "type": "string" },
                  "specialties": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Application submitted successfully" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/geo/departments": {
      "get": {
        "tags": ["Geography"],
        "summary": "Get Colombian departments list",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/geo/cities": {
      "get": {
        "tags": ["Geography"],
        "summary": "Get cities filtered by department ID",
        "parameters": [
          { "name": "department_id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/selects/categories": {
      "get": {
        "tags": ["Select Options"],
        "summary": "Get categories for selects dropdowns",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/selects/product-brands": {
      "get": {
        "tags": ["Select Options"],
        "summary": "Get product brands for selects dropdowns",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/selects/vehicle-brands": {
      "get": {
        "tags": ["Select Options"],
        "summary": "Get vehicle brands for selects dropdowns",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/selects/vehicle-models": {
      "get": {
        "tags": ["Select Options"],
        "summary": "Get vehicle models for selects dropdowns",
        "parameters": [
          { "name": "brand_id", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/selects/vehicle-years": {
      "get": {
        "tags": ["Select Options"],
        "summary": "Get vehicle years for selects dropdowns",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/selects/vehicle-displacements": {
      "get": {
        "tags": ["Select Options"],
        "summary": "Get vehicle displacements for selects dropdowns",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/categories": {
      "get": {
        "tags": ["Admin Categories"],
        "summary": "List categories (Admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Admin Categories"],
        "summary": "Create category (Admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/categories/{id}": {
      "get": {
        "tags": ["Admin Categories"],
        "summary": "Get category details (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Success" } }
      },
      "put": {
        "tags": ["Admin Categories"],
        "summary": "Update category (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Admin Categories"],
        "summary": "Delete category (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/products": {
      "get": {
        "tags": ["Admin Products"],
        "summary": "List products (Admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Admin Products"],
        "summary": "Create product (Admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Admin Products"],
        "summary": "Get product details (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Success" } }
      },
      "put": {
        "tags": ["Admin Products"],
        "summary": "Update product (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Admin Products"],
        "summary": "Delete product (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/carriers": {
      "get": {
        "tags": ["Admin Carriers"],
        "summary": "List carriers (Admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Admin Carriers"],
        "summary": "Create carrier (Admin)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "example": "Servientrega" },
                  "phone": { "type": "string", "example": "1234567" },
                  "email": { "type": "string", "format": "email", "example": "info@servientrega.com" },
                  "status": { "type": "string", "enum": ["active", "inactive"], "example": "active" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/carriers/{id}": {
      "get": {
        "tags": ["Admin Carriers"],
        "summary": "Get carrier details (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Success" } }
      },
      "put": {
        "tags": ["Admin Carriers"],
        "summary": "Update carrier (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "Servientrega" },
                  "phone": { "type": "string", "example": "1234567" },
                  "email": { "type": "string", "format": "email", "example": "info@servientrega.com" },
                  "status": { "type": "string", "enum": ["active", "inactive"], "example": "active" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Admin Carriers"],
        "summary": "Delete carrier (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/dispatches": {
      "get": {
        "tags": ["Admin Dispatches"],
        "summary": "List dispatches (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["pending", "shipped", "delivered", "returned"] } }
        ],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Admin Dispatches"],
        "summary": "Create dispatch (Admin)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["order_id", "carrier_id", "tracking_number", "responsible_person"],
                "properties": {
                  "order_id": { "type": "integer", "example": 1 },
                  "carrier_id": { "type": "integer", "example": 1 },
                  "tracking_number": { "type": "string", "example": "ENV123456789" },
                  "responsible_person": { "type": "string", "example": "Carlos Perez" },
                  "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "returned"], "example": "pending" },
                  "dispatch_date": { "type": "string", "format": "date-time", "example": "2026-06-21T15:00:00Z" },
                  "notes": { "type": "string", "example": "Delivered to reception." }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/dispatches/{id}": {
      "get": {
        "tags": ["Admin Dispatches"],
        "summary": "Get dispatch details (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Success" } }
      },
      "put": {
        "tags": ["Admin Dispatches"],
        "summary": "Update dispatch (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "order_id": { "type": "integer" },
                  "carrier_id": { "type": "integer" },
                  "tracking_number": { "type": "string" },
                  "responsible_person": { "type": "string" },
                  "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "returned"] },
                  "dispatch_date": { "type": "string", "format": "date-time" },
                  "notes": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Admin Dispatches"],
        "summary": "Delete dispatch (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    }
  }
}
